# CodeTribunal - Environment Variables
# Copy this file to .env and fill in your values

# ── Backend Settings ──────────────────────────────────────────

# Application Settings
APP_NAME=CodeTribunal
APP_VERSION=1.0.0
DEBUG=false

# API Settings
API_V1_STR=/api/v1
PROJECT_NAME=CodeTribunal API
HOST=0.0.0.0
PORT=8000

# Database Settings (Neon Serverless PostgreSQL - used by SQLAlchemy ORM)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Qwen API Settings
# Proof of Alibaba Cloud deployment: QWEN_BASE_URL points to Alibaba's Qwen Cloud API
# See: https://dashscope.aliyuncs.com (Alibaba Cloud DashScope)
QWEN_API_KEY=your_qwen_api_key_here
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Model Settings
QWEN_MAX_MODEL=qwen-max
QWEN_PLUS_MODEL=qwen-plus
QWEN_TURBO_MODEL=qwen-turbo

# Agent-Specific Models
AEGIS_MODEL=qwen-max      # For adversarial reasoning and security hunting
ARBITER_MODEL=qwen-max    # For complex orchestration and final verdict
AXIOM_MODEL=qwen-plus     # For counter-arguments and reasoning
METRIC_MODEL=qwen-plus    # For data analysis and complexity metrics
LEDGER_MODEL=qwen-turbo   # For parsing and recording

# Security Settings
SECRET_KEY=change_this_to_a_random_secret_key_for_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS Settings
BACKEND_CORS_ORIGINS=*

# Logging Settings
LOG_LEVEL=INFO
LOG_FILE=codetribunal.log

# Feature Flags
TRACK_TOKEN_USAGE=true

# Maximum debate rounds
MAX_DEBATE_ROUNDS=3

# Confidence threshold for early verdict
CONFIDENCE_THRESHOLD=0.7

# ── Frontend Settings (Next.js) ─────────────────────────────────
# These go in frontend/.env.local for local dev, or Vercel env vars for production

# Backend API URL (REST endpoint for session creation)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Backend WebSocket URL (for real-time trial streaming)
NEXT_PUBLIC_WS_URL=ws://localhost:8000
